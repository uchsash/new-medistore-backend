generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Category {
  id            String     @id @default(uuid())
  name          String     @unique
  description   String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  medicines Medicine[]

  @@index([name])
  @@map("categories")
}

model Medicine {
  id           String      @id @default(uuid())
  name         String
  description  String?
  price        Float
  manufacturer String
  stock        Int         @default(0)
  imageUrl     String?
  
  categoryId   String
  category     Category    @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  sellerId     String
  seller       User        @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  orderItems   OrderItem[]
  reviews      Review[]
  
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([manufacturer])
  @@index([name])
  @@index([categoryId])
  @@index([sellerId])
  @@index([price])

  @@map("medicines")
}

enum OrderStatus {
  PENDING
  SHIPPED
  DELIVERED
  CANCELLED
}

model Order {
  id              String      @id @default(uuid())
  customerId      String
  customer        User        @relation(fields: [customerId], references: [id])
  
  totalAmount     Float
  shippingAddress String
  
  status          OrderStatus @default(PENDING)
  items           OrderItem[]
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([customerId])
  @@index([status])
  @@map("orders")
}

model OrderItem {
  id         String   @id @default(uuid())
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  medicineId String
  medicine   Medicine @relation(fields: [medicineId], references: [id], onDelete: Restrict)
  
  quantity   Int
  price      Float

  @@map("orderItems")
}

enum ReviewStatus {
  PUBLISHED
  UNPUBLISHED
}

model Review {
  id         String   @id @default(uuid())
  rating     Int
  comment    String?
  status     ReviewStatus @default(PUBLISHED)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  medicineId String
  medicine   Medicine @relation(fields: [medicineId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([status])
  @@map("reviews")
}


enum UserRole {
    CUSTOMER
    SELLER
    ADMIN
}

enum UserStatus {
  ACTIVE
  BANNED
}

model User {
  id            String    @id @default(uuid())
  name          String
  email         String    @unique
  password      String
  emailVerified Boolean   @default(false)
  image         String?
  phone         String?
  
  role   UserRole  @default(CUSTOMER)
  status UserStatus @default(ACTIVE)
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  medicines Medicine[]
  reviews   Review[]
  orders    Order[]

  // sessions      Session[]
  // accounts      Account[]

  @@index([name])
  @@index([email])
  @@index([role])
  @@index([status])

  @@map("users")
}
